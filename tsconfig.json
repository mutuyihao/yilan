{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": [
    "*.js",
    "adapters/**/*.js",
    "background/**/*.js",
    "shared/**/*.js",
    "sidebar/**/*.js",
    "types/**/*.d.ts",
    "types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "libs",
    "landing-page",
    "playwright-report",
    "test-results",
    "dist"
  ]
}
